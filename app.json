{
  "expo": {
    "name": "Ventura",
    "slug": "ventura-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ventura",
    "newArchEnabled": true,
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6200EE"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
